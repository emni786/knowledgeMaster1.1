# ============================================================================
# Knowledgemaster — environment variables (dual-database routing)
# ============================================================================
# Copy this file to `.env` and fill in real values. `.env` is gitignored.
# See SETUP.md for step-by-step instructions on how to get each value.
#
# Architecture: ONE URL, TWO Supabase projects.
#   - PUBLIC Supabase = single auth source + storage for all non-admin users
#     (friends/family). Also holds shared "auth-source" tables: profiles,
#     api_tokens, telegram_bots, admin_settings.
#   - PERSONAL Supabase = the admin's private data store (links, collections,
#     etc. owned by the ADMIN_EMAIL user only). Never receives auth.
#
# When the configured ADMIN_EMAIL signs in, server functions route their
# `links`/`collections`/`insights` reads & writes to PERSONAL Supabase
# automatically. Everyone else stays on PUBLIC.
# ============================================================================

# --- PUBLIC Supabase (auth + non-admin data) -------------------------------
# Browser uses VITE_* values for sign-in / sign-up flows. Server functions
# also use the same project for JWT verification + auth-source table reads.
VITE_SUPABASE_URL=https://YOUR-PUBLIC-PROJECT-REF.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=YOUR-PUBLIC-PUBLISHABLE-ANON-KEY
VITE_SUPABASE_PROJECT_ID=YOUR-PUBLIC-PROJECT-REF

# Server-side mirror of the values above (used by SSR / server functions).
SUPABASE_URL=https://YOUR-PUBLIC-PROJECT-REF.supabase.co
SUPABASE_PUBLISHABLE_KEY=YOUR-PUBLIC-PUBLISHABLE-ANON-KEY

# Service role key for PUBLIC Supabase — bypasses RLS. NEVER expose to the
# browser. Used for: extension/save token lookup, telegram webhook, admin
# flag sync, admin_settings read/write, telegram_bots, profiles.
SUPABASE_SERVICE_ROLE_KEY=YOUR-PUBLIC-SERVICE-ROLE-KEY

# --- PERSONAL Supabase (admin's private data) ------------------------------
# Service role key only — admin never authenticates against this project.
# All reads/writes to the admin's links/collections/insights go via the
# service role client (server-side only). The admin's owner_id comes from
# their JWT in PUBLIC Supabase, and queries are manually scoped by owner_id.
#
# Leave both blank if you only want a single Supabase project (admin and
# public users will all share PUBLIC; storage is then capped by PUBLIC's
# free-tier limit).
PERSONAL_SUPABASE_URL=https://YOUR-PERSONAL-PROJECT-REF.supabase.co
PERSONAL_SUPABASE_SERVICE_ROLE_KEY=YOUR-PERSONAL-SERVICE-ROLE-KEY

# --- Admin -----------------------------------------------------------------
# The signup email treated as the deployment's owner. This user's data is
# routed to PERSONAL Supabase, an "Admin settings" + "User management"
# section appears in /settings, and they can edit runtime AI key / model /
# base URL / public app URL from the UI without redeploying.
#
# This owner is permanent for the deployment — set it once and forget it.
# Other users sign up normally and live on PUBLIC. The owner can also
# GRANT admin to any other user via the in-app User management UI
# (sets profiles.is_admin = true). Granted admins can edit the shared
# settings but their own data still lives on PUBLIC — only the
# ADMIN_EMAIL user routes data to PERSONAL.
#
# Leave blank to disable admin-tier entirely; the PERSONAL_* values above
# are then ignored and everyone uses PUBLIC.
ADMIN_EMAIL=me.redwanhossen@gmail.com

# --- AI provider (fallback only) -------------------------------------------
# Default: Google AI Studio (https://aistudio.google.com/apikey). Free tier
# is plenty for personal use. The OpenAI-compatible endpoint is used so any
# other OpenAI-compatible provider also works — just override AI_BASE_URL.
#
# These values are FALLBACKS used until the admin saves values via the
# in-app Settings page. Once saved in the UI, the DB takes precedence.
GOOGLE_AI_API_KEY=YOUR-GOOGLE-AI-STUDIO-KEY

# Optional overrides:
# AI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
# AI_MODEL=gemini-2.5-flash

# --- Public app URL --------------------------------------------------------
# The deployed app's public HTTPS URL. Required for Telegram bot webhook
# registration; the browser extension also uses it. In production set this
# to your Vercel domain (e.g. https://knowledgemaster.vercel.app). Locally
# use an ngrok / cloudflared tunnel URL.
#
# Can be left blank if you set the value from the in-app Admin Settings UI
# (admin_settings.public_app_url) — DB wins, env loses. In production we
# recommend setting BOTH so the very first request (before admin saves
# settings) has a valid URL.
# Example: PUBLIC_APP_URL=https://your-app.vercel.app
PUBLIC_APP_URL=
