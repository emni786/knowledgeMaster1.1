# ============================================================================
# Knowledgemaster — environment variables
# ============================================================================
# Copy this file to `.env` and fill in real values. `.env` is gitignored.
# See SETUP.md for step-by-step instructions on how to get each value.
# ============================================================================

# --- Supabase (https://supabase.com) ---------------------------------------
# Browser-side. Both VITE_* and unprefixed forms are required because the
# unprefixed names are used by server functions (SSR / API routes).
VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=YOUR-PUBLISHABLE-ANON-KEY
VITE_SUPABASE_PROJECT_ID=YOUR-PROJECT-REF

# Server-side mirror of the values above (used by SSR / server functions).
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_PUBLISHABLE_KEY=YOUR-PUBLISHABLE-ANON-KEY

# Service role key — bypasses RLS. NEVER expose to the browser. Used by the
# public extension/save and telegram webhook endpoints.
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# --- Admin -----------------------------------------------------------------
# The signup email that should be treated as the deployment's admin. When
# this user logs in, an "Admin settings" section appears in /settings where
# they can edit the runtime AI key, model, base URL and public app URL from
# the UI without redeploying. Everyone else (friends, family) just signs up
# normally and uses whatever the admin has saved.
# Leave blank to disable admin-tier entirely (everything driven by env).
ADMIN_EMAIL=

# --- AI provider -----------------------------------------------------------
# Default: Google AI Studio (https://aistudio.google.com/apikey). Free tier
# is plenty for personal use. The OpenAI-compatible endpoint is used so any
# other OpenAI-compatible provider also works — just override AI_BASE_URL.
#
# These values act as the FALLBACK if the admin hasn't saved values via the
# in-app admin Settings page yet. Once saved in the UI, the DB takes
# precedence over these env vars.
GOOGLE_AI_API_KEY=YOUR-GOOGLE-AI-STUDIO-KEY

# Optional overrides:
# AI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
# AI_MODEL=gemini-2.5-flash

# --- Public app URL --------------------------------------------------------
# Required for Telegram bot integration when running locally (Telegram needs
# a public HTTPS URL to deliver webhook updates). In production, leave blank
# and the request Host header will be used.
# Same DB-over-env precedence as the AI vars above.
# Example for local dev with cloudflared/ngrok:
# PUBLIC_APP_URL=https://your-tunnel.example.com
PUBLIC_APP_URL=
