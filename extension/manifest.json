{
  "manifest_version": 3,
  "name": "Knowledgemaster — Save link",
  "version": "1.0.0",
  "description": "Save the current tab to your Knowledgemaster library with one click.",
  "permissions": ["activeTab", "storage", "tabs"],
  "host_permissions": ["https://knowledgemaster.lovable.app/*"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Save to Knowledgemaster",
    "default_icon": { "48": "icon.png", "128": "icon.png" }
  },
  "icons": { "48": "icon.png", "128": "icon.png" }
}
